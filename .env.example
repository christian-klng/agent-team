# --- Datenbank & Redis ---
DATABASE_URL=postgres://agentteam:agentteam@localhost:54329/agentteam
REDIS_URL=redis://localhost:63790

# --- Auth ---
# openssl rand -hex 32
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:3000

# --- Verschlüsselung der Datenquellen-Zugangsdaten (64 Hex-Zeichen) ---
# openssl rand -hex 32
APP_ENCRYPTION_KEY=change-me

# --- LLM-Gateway (LiteLLM -> OpenRouter/Cortecs) ---
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-change-me
OPENROUTER_API_KEY=
CORTECS_API_KEY=
# Fallback: direkte Anthropic-API statt Gateway (LITELLM_BASE_URL leer lassen)
ANTHROPIC_API_KEY=

# --- Agent-Runtime ---
# Persistente Daten des Workers (SDK-Sessions, Agent-Workspaces)
AGENT_DATA_DIR=/data
CLAUDE_CONFIG_DIR=/data/claude

# --- Erst-Login (scripts/seed-user.ts) ---
SEED_USER_EMAIL=christian@xplrs.net
SEED_USER_PASSWORD=change-me
SEED_USER_NAME=Christian
